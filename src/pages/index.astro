---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-green-900/50 to-green-950"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40 text-center">
      <div class="mb-8">
        <img src={`${base}/logo.png`} alt="Condor Gilligan Invitational" class="w-40 h-40 sm:w-48 sm:h-48 mx-auto drop-shadow-lg" />
      </div>
      <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight">
        Condor Gilligan<br />
        <span class="text-gold-400">Invitational</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Where tradition meets competition. An annual gathering of golfers united by a shared love of the game.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}/participants/`}
          class="inline-block bg-gold-500 hover:bg-gold-400 text-green-950 font-semibold px-8 py-3 rounded transition-colors text-sm tracking-wide uppercase"
        >
          View Participants
        </a>
        <a
          href={`${base}/rules/`}
          class="inline-block border border-gold-600/50 hover:border-gold-500 text-gold-400 font-semibold px-8 py-3 rounded transition-colors text-sm tracking-wide uppercase"
        >
          Tournament Rules
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="h-px bg-gradient-to-r from-transparent via-gold-700/40 to-transparent"></div>
  </div>

  <!-- Info Cards -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-green-900/30 border border-gold-800/20 rounded-lg p-8 text-center">
        <div class="text-gold-400 text-3xl mb-4 font-serif">&#9971;</div>
        <h3 class="font-serif text-xl text-gold-300 mb-3">The Course</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Details about the course will be announced ahead of each tournament. Stay tuned for updates.
        </p>
      </div>
      <div class="bg-green-900/30 border border-gold-800/20 rounded-lg p-8 text-center">
        <div class="text-gold-400 text-3xl mb-4 font-serif">&#127942;</div>
        <h3 class="font-serif text-xl text-gold-300 mb-3">The Competition</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          A format designed to challenge and entertain. Check the rules page for full tournament details.
        </p>
      </div>
      <div class="bg-green-900/30 border border-gold-800/20 rounded-lg p-8 text-center">
        <div class="text-gold-400 text-3xl mb-4 font-serif">&#127867;</div>
        <h3 class="font-serif text-xl text-gold-300 mb-3">The Social</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          More than just golf. The CGI is about friendships, stories, and memorable moments on and off the course.
        </p>
      </div>
    </div>
  </section>

  <!-- Next Tournament -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="bg-gradient-to-br from-green-900/50 to-green-800/30 border border-gold-700/30 rounded-xl p-10 sm:p-14 text-center">
      <span class="text-gold-600 text-sm font-medium tracking-[0.2em] uppercase">Next Tournament</span>
      <h2 class="font-serif text-3xl sm:text-4xl text-white mt-4 mb-4">Coming Soon</h2>
      <p class="text-gray-400 max-w-lg mx-auto">
        The next edition of the Condor Gilligan Invitational is being planned. Details will be announced here.
      </p>
    </div>
  </section>
</Layout>
