---
import Layout from '../layouts/Layout.astro';
import data from '../data/tournaments.json';

const base = import.meta.env.BASE_URL;
const { tournaments, players } = data;

// Map player names to avatar filenames
const avatars: Record<string, string> = {
  'Fredrik Karåker': 'fredrik',
  'Rasmus Gustafson': 'rasmus',
  'Johan Bäckström': 'johan',
  'Erik Larsson': 'erik',
  'Anthony Smith': 'anthony',
  'Carl Beling': 'carl',
  'Axel Philipson': 'axel',
  'Sebastian Ahlström': 'sebastian',
  'Mikael Bäckman': 'micke',
  'Oscar Rosander': 'oscar',
  'David Wasserman': 'david',
};

// Count wins per player
const wins: Record<string, number> = {};
for (const t of tournaments) {
  const winner = t.results[0].player;
  wins[winner] = (wins[winner] || 0) + 1;
}

// Get placement for a player in each tournament (null = didn't participate)
function getPlacements(playerName: string): (number | null)[] {
  return tournaments.map((t) => {
    const idx = t.results.findIndex(r => r.player === playerName);
    return idx === -1 ? null : idx + 1;
  });
}
---

<Layout title="Participants">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="text-center mb-16">
      <span class="text-gold-600 text-sm font-medium tracking-[0.2em] uppercase">The Field</span>
      <h1 class="font-serif text-4xl sm:text-5xl text-white mt-4">Participants</h1>
      <p class="text-gray-400 mt-4 max-w-xl mx-auto">
        Every golfer who has competed in the Condor Gilligan Invitational.
      </p>
    </div>

    <!-- Stats -->
    <div class="flex justify-center gap-8 sm:gap-16 mb-16">
      <div class="text-center">
        <p class="text-gold-400 font-serif text-3xl sm:text-4xl font-bold">{players.length}</p>
        <p class="text-gray-500 text-sm mt-1">Total Players</p>
      </div>
      <div class="text-center">
        <p class="text-gold-400 font-serif text-3xl sm:text-4xl font-bold">{tournaments.length}</p>
        <p class="text-gray-500 text-sm mt-1">Tournaments</p>
      </div>
    </div>

    <!-- Participant table -->
    <div class="max-w-3xl mx-auto">
      <div class="bg-green-900/30 border border-gold-800/20 rounded-xl overflow-hidden">
        <div class="grid grid-cols-[1fr_auto] gap-4 px-6 py-3 border-b border-gold-800/20">
          <p class="text-gold-600 text-xs font-medium tracking-wider uppercase">Player</p>
          <p class="text-gold-600 text-xs font-medium tracking-wider uppercase text-center">Results</p>
        </div>
        {players.map((p, i) => {
          const placements = getPlacements(p.name);
          return (
            <div class:list={[
              'grid grid-cols-[1fr_auto] gap-4 px-6 py-4 items-center',
              i < players.length - 1 && 'border-b border-gold-800/10',
            ]}>
              <div class="flex items-center gap-3">
                <img
                  src={`${base}/avatars/sm/${avatars[p.name]}.png`}
                  alt={p.name}
                  class="w-12 h-12 rounded-full object-cover border border-gold-800/30 shrink-0"
                />
                <div>
                  <span class="text-white font-medium">{p.name}</span>
                  {wins[p.name] && (
                    <span class="text-gold-500 text-xs ml-2">
                      {'🏆'.repeat(wins[p.name])}
                    </span>
                  )}
                </div>
              </div>
              <div class="flex items-center justify-center gap-1.5">
                {tournaments.map((t, j) => (
                  <div class:list={[
                    'w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold',
                    p.events[j]
                      ? t.type === 'winter'
                        ? 'bg-sky-400/20 border border-sky-400/40'
                        : 'bg-gold-500/20 border border-gold-500/40'
                      : 'bg-green-800/30 border border-green-800/50',
                  ]}>
                    <span class:list={[
                      p.events[j]
                        ? placements[j] === 1
                          ? 'text-gold-400'
                          : placements[j] !== null && placements[j]! <= 3
                            ? 'text-gold-500'
                            : t.type === 'winter' ? 'text-sky-400' : 'text-gold-600'
                        : 'text-green-800/60',
                    ]}>
                      {placements[j] !== null ? placements[j] : '–'}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap justify-center gap-6 mt-6">
        <div class="flex items-center gap-2">
          <div class="w-2.5 h-2.5 rounded-full bg-gold-500"></div>
          <span class="text-gray-500 text-xs">Summer Edition</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2.5 h-2.5 rounded-full bg-sky-400"></div>
          <span class="text-gray-500 text-xs">Winter Edition</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
