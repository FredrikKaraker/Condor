---
import Layout from '../layouts/Layout.astro';
import SwedenMap from '../components/SwedenMap.astro';
import WeatherIcon from '../components/WeatherIcon.astro';
import data from '../data/tournaments.json';
const base = import.meta.env.BASE_URL;

const tournaments = [...data.tournaments].reverse();

const avatars: Record<string, string> = {
  'Fredrik Karåker': 'fredrik',
  'Rasmus Gustafson': 'rasmus',
  'Johan Bäckström': 'johan',
  'Erik Larsson': 'erik',
  'Anthony Smith': 'anthony',
  'Carl Beling': 'carl',
  'Axel Philipson': 'axel',
  'Sebastian Ahlström': 'sebastian',
  'Mikael Bäckman': 'micke',
  'Oscar Rosander': 'oscar',
  'David Wasserman': 'david',
};
---

<Layout title="History">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="text-center mb-16">
      <span class="text-gold-600 text-sm font-medium tracking-[0.2em] uppercase">The Legacy</span>
      <h1 class="font-serif text-4xl sm:text-5xl text-white mt-4">Tournament History</h1>
      <p class="text-gray-400 mt-4 max-w-xl mx-auto">
        A record of every Condor Gilligan Invitational.
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 lg:gap-10">
      <!-- Map (sticky on large screens) -->
      <div class="lg:w-72 xl:w-80 shrink-0">
        <div class="lg:sticky lg:top-24">
          <SwedenMap />
        </div>
      </div>

      <!-- Tournament list -->
      <div class="flex-1 space-y-6">
        {tournaments.map((t) => (
          <a href={`${base}/history/${t.slug}/`} class="block group">
            <div class="bg-green-900/30 border border-gold-800/20 rounded-xl p-6 sm:p-8 transition-colors group-hover:border-gold-700/40">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
                <div class="flex items-center gap-4">
                  <span class="text-gold-500 font-serif text-2xl sm:text-3xl font-bold">{t.year}</span>
                  <div>
                    <h2 class="text-white font-serif text-lg sm:text-xl">{t.title}</h2>
                    <div class="flex items-center gap-2">
                      <p class="text-gray-500 text-sm">{t.dates}</p>
                      {t.weather && (
                        <span class="flex items-center gap-1 text-gray-500 text-sm">
                          <WeatherIcon icon={t.weather.icon} class="w-4 h-4" />
                          {t.weather.tempC}°C
                        </span>
                      )}
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-2 mt-3 sm:mt-0">
                  {t.type === 'winter' && (
                    <span class="text-xs bg-sky-400/10 text-sky-400 border border-sky-400/20 rounded-full px-3 py-1">Winter</span>
                  )}
                  <span class="text-gold-600 text-sm group-hover:text-gold-400 transition-colors">View details &rarr;</span>
                </div>
              </div>
              <div class="h-px bg-gold-800/20 mb-4"></div>
              <div class="grid sm:grid-cols-3 gap-4">
                <div>
                  <p class="text-gold-600 text-xs font-medium tracking-wider uppercase mb-2">Champion</p>
                  <div class="flex items-center gap-3">
                    <img
                      src={`${base}/avatars/sm/${avatars[t.results[0].player]}.png`}
                      alt={t.results[0].player}
                      class="w-14 h-14 rounded-full object-cover border-2 border-gold-500/50 shrink-0"
                    />
                    <div>
                      <p class="text-white font-medium">{t.results[0].player}</p>
                      {t.results[0].points && (
                        <p class="text-gray-500 text-sm">{t.results[0].points} pts</p>
                      )}
                    </div>
                  </div>
                </div>
                {t.results.length > 1 && (
                  <div>
                    <p class="text-gold-600 text-xs font-medium tracking-wider uppercase mb-2">Runner-up</p>
                    <div class="flex items-center gap-3">
                      <img
                        src={`${base}/avatars/sm/${avatars[t.results[1].player]}.png`}
                        alt={t.results[1].player}
                        class="w-14 h-14 rounded-full object-cover border-2 border-gold-800/30 shrink-0"
                      />
                      <div>
                        <p class="text-white font-medium">{t.results[1].player}</p>
                        {t.results[1].points && (
                          <p class="text-gray-500 text-sm">{t.results[1].points} pts</p>
                        )}
                      </div>
                    </div>
                  </div>
                )}
                <div>
                  <p class="text-gold-600 text-xs font-medium tracking-wider uppercase mb-1">Courses</p>
                  <p class="text-gray-400 text-sm">{t.courses.join(', ')}</p>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="text-center mt-16">
      <div class="inline-block bg-green-900/30 border border-gold-800/20 rounded-lg px-8 py-6">
        <p class="text-gray-400 text-sm">
          History is written with every swing. More editions to come.
        </p>
      </div>
    </div>
  </section>
</Layout>
